# ── Local Development (Floci) ──────────────────────────────────────────────────
# Remove AWS_ENDPOINT in production — the SDK will use IAM Role from ECS Fargate
AWS_ENDPOINT=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── SQS ────────────────────────────────────────────────────────────────────────
# Floci format: http://localhost:4566/000000000000/<queue-name>
SQS_PAYMENT_QUEUE_URL=http://localhost:4566/000000000000/payment-queue

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_gateway
